# Puerto donde expondrá la app en el host (mapea HOST:CONTAINER(8080))
APP_PORT=8090

# RabbitMQ (si RabbitMQ está en el host local Windows, puedes usar host.docker.internal)
# Si RabbitMQ está en otro servidor, pon la ip/hostname allí.
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123

# Perfil de Spring (opcional)
SPRING_PROFILES_ACTIVE=default

# JAVA_OPTS (opcional): ejemplo para limitar heap
JAVA_OPTS="-Xms256m -Xmx512m"
